{
  "name": "@rtrvr-ai/rover",
  "version": "4.2.1",
  "license": "FSL-1.1-Apache-2.0",
  "description": "Turn any website into an AI-native interface — for your users and for AI.",
  "author": "RTRVR AI, INC. <support@rtrvr.ai>",
  "homepage": "https://www.rtrvr.ai/rover",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtrvr-ai/rover.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/rtrvr-ai/rover/issues"
  },
  "keywords": [
    "rover",
    "web-agent",
    "ai-agent",
    "automation",
    "embedded",
    "dom",
    "browser-automation",
    "autonomous-agent",
    "sdk",
    "electron",
    "browser-extension",
    "chrome-extension",
    "agentic",
    "deep-link",
    "accessibility",
    "open-source",
    "dom-agent",
    "ai-web-agent"
  ],
  "private": false,
  "type": "module",
  "main": "dist/rover.js",
  "module": "dist/rover.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/rover.js",
      "types": "./dist/index.d.ts"
    },
    "./agent-discovery": {
      "import": "./dist/agentDiscovery.js",
      "types": "./dist/agentDiscovery.d.ts"
    },
    "./preview-bootstrap": {
      "import": "./dist/previewBootstrap.js",
      "types": "./dist/previewBootstrap.d.ts"
    },
    "./owner-install": {
      "import": "./dist/ownerInstall.js",
      "types": "./dist/ownerInstall.d.ts"
    },
    "./embed": "./dist/embed.js",
    "./worker": "./dist/worker/rover-worker.js"
  },
  "files": [
    "dist/rover.js",
    "dist/agentDiscovery.js",
    "dist/agentDiscovery.d.ts",
    "dist/embed.js",
    "dist/ownerInstall.js",
    "dist/ownerInstall.d.ts",
    "dist/previewBootstrap.js",
    "dist/previewBootstrap.d.ts",
    "dist/index.d.ts",
    "dist/worker/rover-worker.js",
    "dist/loader.js",
    "dist/loader.d.ts",
    "dist/rolls-cli.mjs",
    "README.md"
  ],
  "bin": {
    "rtrvr-rolls": "./dist/rolls-cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && node ./scripts/copy-worker.mjs && node ./scripts/bundle.mjs && node ./scripts/build-embed.mjs",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "node --test --test-force-exit tests/**/*.test.mjs"
  },
  "dependencies": {
    "@rover/bridge": "workspace:*",
    "@rover/ui": "workspace:*",
    "@rover/shared": "workspace:*"
  },
  "devDependencies": {
    "@rover/tsconfig": "workspace:*",
    "@rover/worker": "workspace:*",
    "@types/node": "^20.11.30",
    "typescript": "^5.6.3"
  }
}
